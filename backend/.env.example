# Copy to .env and fill in. .env is gitignored.

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-prod

# Auth — generate a strong random value for production
JWT_SECRET_KEY=change-me-too

# Database
# Dev: leave unset to use a local SQLite file (backend/dev.sqlite3).
# Prod (Render): set to the Postgres connection URL, e.g.
#   postgresql://user:pass@host:5432/dbname
# DATABASE_URL=

# Comma-separated list of allowed CORS origins (frontend URLs).
# Dev default covers Vite. In prod, set to your Vercel URL only.
CORS_ORIGINS=http://localhost:5173

# LLM (Phase 3+) — not used yet.
# LLM_PROVIDER=ollama        # ollama | gemini
# LLM_API_KEY=
